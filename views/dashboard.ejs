<%- include('partials/header', { title: "Dashboard", active: "dashboard", toast, customCss: null }) %>
<%- include('partials/sidebar', { active: "dashboard" }) %>
<div class="main-content">
  <h2>Dashboard</h2>
  <div class="row g-4 mb-4">
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="display-5 fw-bold text-primary mb-2"><%= stats.produk %></div>
        <div class="fw-medium">Produk</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="display-5 fw-bold text-success mb-2"><%= stats.promo %></div>
        <div class="fw-medium">Promo</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="display-5 fw-bold text-info mb-2"><%= stats.faq %></div>
        <div class="fw-medium">FAQ</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="display-5 fw-bold text-secondary mb-2"><%= stats.sop %></div>
        <div class="fw-medium">SOP</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="display-5 fw-bold text-warning mb-2"><%= stats.claim %></div>
        <div class="fw-medium">Claim</div>
      </div>
    </div>
  </div>
  <div class="card p-4">
    <h5>Statistik Data</h5>
    <canvas id="statsChart" height="70"></canvas>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const stats = <%- JSON.stringify(stats) %>;
  new Chart(document.getElementById('statsChart').getContext('2d'), {
    type: 'bar',
    data: {
      labels: Object.keys(stats),
      datasets: [{
        label: 'Jumlah',
        data: Object.values(stats),
        backgroundColor: '#3b82f6'
      }]
    },
    options: { responsive: true }
  });
</script>
<%- include('partials/footer') %>
