<%- include('partials/header', { title: "Promo", active: "promo", toast, customCss: null }) %>
<%- include('partials/sidebar', { active: "promo" }) %>
<div class="main-content">
  <h2>Banner Promo</h2>
  <% if (role === 'owner') { %>
  <form method="post" action="/promo/save" class="card mb-4">
    <input type="hidden" name="idx" value="">
    <div>
      <label>Isi Banner:</label>
      <textarea name="banner" required class="input"></textarea>
    </div>
    <div>
      <label>Aktif?</label>
      <input type="checkbox" name="active" checked>
    </div>
    <button type="submit" class="btn">Tambah Promo</button>
  </form>
  <% } %>
  <% if (promo && promo.length > 0) { %>
    <div class="card">
      <table>
        <thead><tr><th>No</th><th>Banner</th><th>Status</th><th></th></tr></thead>
        <tbody>
        <% promo.forEach((item, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><%= item.banner %></td>
            <td><%= item.active ? "Aktif" : "Nonaktif" %></td>
            <td>
              <% if (role === 'owner') { %>
              <form method="post" action="/promo/delete" style="display:inline">
                <input type="hidden" name="idx" value="<%= i %>">
                <button class="btn btn-danger" onclick="return confirm('Hapus promo ini?')">🗑️</button>
              </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="card">Belum ada promo.</div>
  <% } %>
</div>
<%- include('partials/footer') %>
