<%- include('partials/header', { title: "SOP", active: "sop", toast, customCss: null }) %>
<%- include('partials/sidebar', { active: "sop" }) %>
<div class="main-content">
  <h2>SOP (Standard Operating Procedure)</h2>
  <% if (role === 'owner') { %>
  <form method="post" action="/sop/save" class="card mb-4">
    <input type="hidden" name="idx" value="">
    <div>
      <label>Trigger (pisahkan koma):</label>
      <input type="text" name="trigger" required class="input">
    </div>
    <div>
      <label>Response:</label>
      <textarea name="response" required class="input"></textarea>
    </div>
    <button type="submit" class="btn">Tambah SOP</button>
  </form>
  <% } %>
  <% if (sop && sop.length > 0) { %>
    <div class="card">
      <table class="table-modern">
        <thead><tr><th>No</th><th>Trigger</th><th>Response</th><th></th></tr></thead>
        <tbody>
        <% sop.forEach((item, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><%= item.trigger.join(', ') %></td>
            <td><%= item.response %></td>
            <td>
              <% if (role === 'owner') { %>
              <form method="post" action="/sop/delete" style="display:inline">
                <input type="hidden" name="file" value="<%= item.file %>">
                <button class="btn btn-danger" onclick="return confirm('Hapus SOP ini?')">🗑️</button>
              </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="card">Belum ada SOP.</div>
  <% } %>
</div>
<%- include('partials/footer') %>
